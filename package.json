{
  "name": "open-tristam",
  "version": "1.0.39",
  "private": true,
  "dependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@fortawesome/fontawesome-svg-core": "^1.2.21",
    "@fortawesome/free-solid-svg-icons": "^5.10.1",
    "@fortawesome/react-fontawesome": "^0.1.4",
    "axios": "^0.21.1",
    "babel-jest": "^29.7.0",
    "camelcase": "^5.2.0",
    "classnames": "^2.2.6",
    "dotenv": "6.2.0",
    "dotenv-expand": "4.2.0",
    "eslint": "^8.57.1",
    "eslint-config-react-app": "^4.0.1",
    "eslint-plugin-flowtype": "2.50.1",
    "eslint-plugin-import": "2.16.0",
    "eslint-plugin-jsx-a11y": "^6.2.1",
    "eslint-plugin-react": "^7.12.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fs-extra": "7.0.1",
    "idb-kv-store": "^4.4.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom-fourteen": "0.1.0",
    "jest-resolve": "24.7.1",
    "jest-watch-typeahead": "^2.2.2",
    "peerjs": "1.4.7",
    "react": "^18.3.1",
    "react-app-polyfill": "^1.0.1",
    "react-dom": "^18.3.1",
    "react-ga": "^2.6.0",
    "resolve": "1.10.0",
    "sourcemapped-stacktrace": "^1.1.9"
  },
  "scripts": {
    "build": "vite build",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "deploy": "gh-pages -d build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src --ext .js,.jsx",
    "prepare": "husky",
    "preview": "vite preview",
    "smoke:retail": "node scripts/retail-smoke.mjs",
    "start": "vite",
    "test": "node scripts/test.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "setupFiles": [
      "react-app-polyfill/jsdom"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.js"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
      "<rootDir>/src/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "<rootDir>/node_modules/babel-jest",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^.+\\.(wasm|jscc|bmp|gif|jpe?g|png|svg)$": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ],
    "modulePaths": [],
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy",
      "\\.wasm(\\?url)?$": "<rootDir>/config/jest/fileMock.js",
      "\\.jscc$": "<rootDir>/config/jest/fileMock.js",
      "\\.(txt|png|bmp|gif|jpe?g|svg)(\\?url)?$": "<rootDir>/config/jest/fileMock.js",
      "\\?worker$": "<rootDir>/config/jest/workerMock.js"
    },
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    }
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react"
    ]
  },
  "homepage": "https://awest813.github.io/OpenTristam",
  "devDependencies": {
    "@babel/core": "^7.14.6",
    "@babel/preset-env": "^7.14.7",
    "@babel/preset-react": "^7.14.5",
    "@playwright/test": "^1.54.2",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-security": "^3.0.1",
    "exports-loader": "^0.7.0",
    "gh-pages": "^2.0.1",
    "husky": "^9.1.7",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.1",
    "playwright-core": "^1.59.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.6.2",
    "sass": "^1.77.0",
    "vite": "^6.4.1",
    "worker-loader": "^2.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,json,md,scss,css,yml,yaml,html}": [
      "prettier --write"
    ],
    "src/**/*.{js,jsx}": [
      "eslint --max-warnings 0"
    ]
  }
}
